              </alternative>
            </choose>
            <loop mode="pre_test" condition="loop" a:alt_id="14" language="text/javascript">
              <call id="a17" endpoint="" a:alt_id="9">
                <parameters>
                  <label>storehouse  processes the part list</label>
                  <method/>
                  <type>:task</type>
                  <arguments/>
