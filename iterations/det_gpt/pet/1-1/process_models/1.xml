      </call>
      <call id="a9" endpoint="" a:alt_id="4">
        <parameters>
          <label>sales department informs the storehouse</label>
          <method/>
          <type>:task</type>
          <arguments/>
        </parameters>
      </call>
      <call id="a11" endpoint="" a:alt_id="5">
        <parameters>
          <label>sales department  informs the engineering department</label>
          <method/>
          <type>:task</type>
          <arguments/>
        </parameters>
      </call>
      <parallel wait="-1" cancel="last" a:alt_id="6">
        <parallel_branch>
          <call id="a15" endpoint="" a:alt_id="7">
            <parameters>
              <label>engineering department prepares for the bike assembling</label>
