              </call>
              <call id="a21" endpoint="" a:alt_id="10">
                <parameters>
                  <label>storehouse checks the  quantity of  parts</label>
                  <method/>
                  <type>:task</type>
                  <arguments/>
                </parameters>
              </call>
              <choose mode="exclusive" a:alt_id="11">
                <alternative condition="enough parts" language="text/javascript">
                  <call id="a25" endpoint="" a:alt_id="12">
                    <parameters>
                      <label>storehouse  reserves the part</label>
                      <method/>
                      <type>:task</type>
                      <arguments/>
