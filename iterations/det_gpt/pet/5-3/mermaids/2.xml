flowchart LR
0:startevent:((startevent))
1:task:(employee submits an office supply request)
2:task:(register the request)
3:task:(immediate supervisor receives request)
4:task:(immediate supervisor approves request)
5:exclusivegateway:{x}
6:task:(immediate supervisor returns request to the employee)
7:task:(employee reviews the comments)
8:exclusivegateway:{x}
9:task:(request goes to the purchase department)
10:task:(the purchase department makes quotations)
11:task:(the purchase department selects vendor)
12:exclusivegateway:{x}
13:task:(the purchase department chooses a different vendor)
14:exclusivegateway:{x}
15:task:(the system  generates a purchase order)
16:task:(the system sends a purchase order)
17:task:(the system waits for the product delivery)
18:task:(the system receives the invoice)
19:exclusivegateway:{x}
20:task:(the system sends user notification)
21:endevent:(((endevent)))

0:startevent:((startevent)) --> 1:task:(employee submits an office supply request)
1:task:(employee submits an office supply request) --> 2:task:(register the request)
2:task:(register the request) --> 3:task:(immediate supervisor receives request)
3:task:(immediate supervisor receives request) --> 4:task:(immediate supervisor approves request)
4:task:(immediate supervisor approves request) --> 5:exclusivegateway:{x}

%% D1 Branch 1: Returned
5:exclusivegateway:{x} --> |Returned|6:task:(immediate supervisor returns request to the employee)
6:task:(immediate supervisor returns request to the employee) --> 7:task:(employee reviews the comments)
7:task:(employee reviews the comments) --> 8:exclusivegateway:{x}

%% D1 Branch 2: No action (default branch)
5:exclusivegateway:{x} --> |No action|8:exclusivegateway:{x}

%% D1 Branch 3: Request proceeds to purchase department
5:exclusivegateway:{x} --> |Request approved|9:task:(request goes to the purchase department)
9:task:(request goes to the purchase department) --> 10:task:(the purchase department makes quotations)
10:task:(the purchase department makes quotations) --> 11:task:(the purchase department selects vendor)
11:task:(the purchase department selects vendor) --> 12:exclusivegateway:{x}

%% D2 Branch 1: Change vendor
12:exclusivegateway:{x} --> |Change vendor|13:task:(the purchase department chooses a different vendor)
13:task:(the purchase department chooses a different vendor) --> 14:exclusivegateway:{x}

%% D2 Branch 2: Vendor OK
12:exclusivegateway:{x} --> |Vendor OK|14:exclusivegateway:{x}

%% D2 Merge
14:exclusivegateway:{x} --> 15:task:(the system  generates a purchase order)
15:task:(the system  generates a purchase order) --> 16:task:(the system sends a purchase order)
16:task:(the system sends a purchase order) --> 17:task:(the system waits for the product delivery)
17:task:(the system waits for the product delivery) --> 18:task:(the system receives the invoice)
18:task:(the system receives the invoice) --> 8:exclusivegateway:{x}

%% D1 Merge
8:exclusivegateway:{x} --> 19:exclusivegateway:{x}

%% After D1 merge
19:exclusivegateway:{x} --> 20:task:(the system sends user notification)
20:task:(the system sends user notification) --> 21:endevent:(((endevent)))