<?xml version="1.0"?>
<description xmlns="http://cpee.org/ns/description/1.0" xmlns:a="http://cpee.org/ns/annotation/1.0">
  <choose mode="exclusive" a:alt_id="1">
    <alternative condition="D1: Fault detector reports failure" language="text/javascript">
      <call id="a3" endpoint="" a:alt_id="2">
        <parameters>
          <label>Fault detector reports a failure to the MPO</label>
          <method/>
          <type>:task</type>
          <arguments/>
        </parameters>
      </call>
    </alternative>
    <alternative condition="D1: MPO suspects own fault" language="text/javascript">
      <call id="a5" endpoint="" a:alt_id="3">
        <parameters>
          <label>MPO has a suspicion of  own fault</label>
          <method/>
          <type>:task</type>
          <arguments/>
        </parameters>
      </call>
    </alternative>
  </choose>
  <choose mode="exclusive" a:alt_id="4">
    <alternative condition="">
      <call id="a11" endpoint="" a:alt_id="5">
        <parameters>
          <label>MPO  examines the failure</label>
          <method/>
          <type>:task</type>
          <arguments/>
        </parameters>
      </call>
      <choose mode="exclusive" a:alt_id="6">
        <alternative condition="D2: Rejects failure" language="text/javascript">
          <call id="a17" endpoint="" a:alt_id="7">
            <parameters>
              <label>MPO rejects the failure of the fault detector</label>
              <method/>
              <type>:task</type>
              <arguments/>
            </parameters>
          </call>
        </alternative>
        <alternative condition="D2: Confirms failure" language="text/javascript">
          <call id="a19" endpoint="" a:alt_id="8">
            <parameters>
              <label>MPO confirms the failure of the fault detector</label>
              <method/>
              <type>:task</type>
              <arguments/>
            </parameters>
          </call>
          <call id="a23" endpoint="" a:alt_id="9">
            <parameters>
              <label>MPO informes the GO</label>
              <method/>
              <type>:task</type>
              <arguments/>
            </parameters>
          </call>
          <call id="a25" endpoint="" a:alt_id="10">
            <parameters>
              <label>MPO informes the MSP</label>
              <method/>
              <type>:task</type>
              <arguments/>
            </parameters>
          </call>
          <call id="a27" endpoint="" a:alt_id="11">
            <parameters>
              <label>MPO fixes the fault at the measuring device</label>
              <method/>
              <type>:task</type>
              <arguments/>
            </parameters>
          </call>
          <call id="a29" endpoint="" a:alt_id="12">
            <parameters>
              <label>MPO shares the results of the repairs</label>
              <method/>
              <type>:task</type>
              <arguments/>
            </parameters>
          </call>
          <call id="a31" endpoint="" a:alt_id="13">
            <parameters>
              <label>MPO informs the GO about the resolution of the interference</label>
              <method/>
              <type>:task</type>
              <arguments/>
            </parameters>
          </call>
          <call id="a33" endpoint="" a:alt_id="14">
            <parameters>
              <label>MPO informs the MSP about the resolution of the interference</label>
              <method/>
              <type>:task</type>
              <arguments/>
            </parameters>
          </call>
        </alternative>
      </choose>
    </alternative>
    <alternative condition="D2: Branch 2" language="text/javascript"/>
  </choose>
</description>
