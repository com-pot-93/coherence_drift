<?xml version="1.0"?>
<description xmlns="http://cpee.org/ns/description/1.0" xmlns:a="http://cpee.org/ns/annotation/1.0">
  <call id="a1" endpoint="" a:alt_id="1">
    <parameters>
      <label>HFD detects a number of personnel requirements</label>
      <method/>
      <type>:task</type>
      <arguments/>
    </parameters>
  </call>
  <call id="a3" endpoint="" a:alt_id="2">
    <parameters>
      <label>HFD reports the vacancy to Personnel Department</label>
      <method/>
      <type>:task</type>
      <arguments/>
    </parameters>
  </call>
  <loop mode="pre_test" condition="true">
    <call id="a7" endpoint="" a:alt_id="4">
      <parameters>
        <label>HFD gets the job description for review from Personnel Department</label>
        <method/>
        <type>:task</type>
        <arguments/>
      </parameters>
    </call>
    <choose mode="exclusive" a:alt_id="5">
      <alternative condition="Corrections needed" language="text/javascript">
        <call id="a11" endpoint="" a:alt_id="6">
          <parameters>
            <label>HFD asks for corrections</label>
            <method/>
            <type>:task</type>
            <arguments/>
          </parameters>
        </call>
      </alternative>
      <alternative condition="Approved" language="text/javascript">
        <call id="a13" endpoint="" a:alt_id="8">
          <parameters>
            <label>HFD approves the job description</label>
            <method/>
            <type>:task</type>
            <arguments/>
          </parameters>
        </call>
        <call id="a17" endpoint="" a:alt_id="9">
          <parameters>
            <label>HFD advertizes the vacancy</label>
            <method/>
            <type>:task</type>
            <arguments/>
          </parameters>
        </call>
        <escape a:alt_id="-1"/>
      </alternative>
    </choose>
  </loop>
</description>
