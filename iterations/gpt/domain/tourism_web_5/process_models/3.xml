<?xml version="1.0"?>
<description xmlns="http://cpee.org/ns/description/1.0" xmlns:a="http://cpee.org/ns/annotation/1.0">
  <call id="a1" endpoint="" a:alt_id="1">
    <parameters>
      <label>Receive Booking Request</label>
      <method/>
      <type>:task</type>
      <arguments/>
    </parameters>
  </call>
  <call id="a3" endpoint="" a:alt_id="2">
    <parameters>
      <label>Process Booking Request</label>
      <method/>
      <type>:task</type>
      <arguments/>
    </parameters>
  </call>
  <loop mode="pre_test" condition="Continue process">
    <call id="a7" endpoint="" a:alt_id="4">
      <parameters>
        <label>Check Availability</label>
        <method/>
        <type>:task</type>
        <arguments/>
      </parameters>
    </call>
    <choose mode="exclusive" a:alt_id="5">
      <alternative condition="Requested time not available" language="text/javascript">
        <call id="a13" endpoint="" a:alt_id="6">
          <parameters>
            <label>Propose Alternative Time</label>
            <method/>
            <type>:task</type>
            <arguments/>
          </parameters>
        </call>
        <call id="a17" endpoint="" a:alt_id="7">
          <parameters>
            <label>Notify Requester of Alternative</label>
            <method/>
            <type>:task</type>
            <arguments/>
          </parameters>
        </call>
        <call id="a19" endpoint="" a:alt_id="8">
          <parameters>
            <label>Await Requester Response</label>
            <method/>
            <type>:task</type>
            <arguments/>
          </parameters>
        </call>
      </alternative>
      <alternative condition="Requested time available" language="text/javascript">
        <call id="a15" endpoint="" a:alt_id="16">
          <parameters>
            <label>Notify Requester</label>
            <method/>
            <type>:task</type>
            <arguments/>
          </parameters>
        </call>
        <call id="a23" endpoint="" a:alt_id="17">
          <parameters>
            <label>Await Requester Response</label>
            <method/>
            <type>:task</type>
            <arguments/>
          </parameters>
        </call>
      </alternative>
    </choose>
    <choose mode="exclusive" a:alt_id="9">
      <alternative condition="Bill needed" language="text/javascript">
        <call id="a27" endpoint="" a:alt_id="10">
          <parameters>
            <label>Send Bill</label>
            <method/>
            <type>:task</type>
            <arguments/>
          </parameters>
        </call>
        <choose mode="exclusive" a:alt_id="11">
          <alternative condition="No further billing" language="text/javascript"/>
          <alternative condition="Further billing needed" language="text/javascript">
            <call id="a27" endpoint="" a:alt_id="10">
              <parameters>
                <label>Send Bill</label>
                <method/>
                <type>:task</type>
                <arguments/>
              </parameters>
            </call>
            <escape a:alt_id="-1"/>
          </alternative>
        </choose>
      </alternative>
      <alternative condition="No bill needed" language="text/javascript"/>
    </choose>
    <call id="a29" endpoint="" a:alt_id="12">
      <parameters>
        <label>Confirm Booking</label>
        <method/>
        <type>:task</type>
        <arguments/>
      </parameters>
    </call>
    <choose mode="exclusive" a:alt_id="13">
      <alternative condition="Escalation needed" language="text/javascript">
        <call id="a39" endpoint="" a:alt_id="14">
          <parameters>
            <label>Handle Escalation</label>
            <method/>
            <type>:task</type>
            <arguments/>
          </parameters>
        </call>
      </alternative>
      <alternative condition="No escalation" language="text/javascript"/>
    </choose>
    <choose mode="exclusive" a:alt_id="15">
      <alternative condition="Repeat booking" language="text/javascript"/>
      <alternative condition="Process complete" language="text/javascript">
        <escape a:alt_id="-1"/>
      </alternative>
    </choose>
  </loop>
</description>
