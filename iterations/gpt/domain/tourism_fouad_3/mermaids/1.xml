0:startevent:((startevent)) --> 1:task:(Receive Travel Request)
1:task:(Receive Travel Request) --> 2:task:(Prepare Tour Plan)
2:task:(Prepare Tour Plan) --> 3:task:(Send Tour Plan)
3:task:(Send Tour Plan) --> 4:task:(Wait for Response)
