7:exclusivegateway:{x} --> |Positive outcome|8:task:(Charge Customer)
7:exclusivegateway:{x} --> |Do not continue|14:exclusivegateway:{x}

8:task:(Charge Customer) --> 9:exclusivegateway:{x}

%% Decision after charging customer
9:exclusivegateway:{x} --> |Contact customer|10:task:(Contact Customer)
9:exclusivegateway:{x} --> |Send bill|11:task:(Send Bill)

10:task:(Contact Customer) --> 13:exclusivegateway:{x}
11:task:(Send Bill) --> 12:task:(Send Booking Confirmation)
12:task:(Send Booking Confirmation) --> 13:exclusivegateway:{x}

%% Merge after customer contact or bill/confirmation
13:exclusivegateway:{x} --> 9:exclusivegateway:{x}

%% If process does not continue after booking, go back to previous decision
14:exclusivegateway:{x} --> 5:exclusivegateway:{x}