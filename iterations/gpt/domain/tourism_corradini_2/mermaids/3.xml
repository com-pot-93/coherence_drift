12:exclusivegateway:{x} --> |Do not continue|13:task:(Contact Customer)

13:task:(Contact Customer) --> 14:exclusivegateway:{x}
14:exclusivegateway:{x} --> 12:exclusivegateway:{x}

15:task:(Book Travel) --> 16:task:(Send Booking Confirmation)
