                    <parameters>
                      <label>Childbirth</label>
                      <method/>
                      <type>:task</type>
                      <arguments/>
                    </parameters>
                  </call>
                  <choose mode="exclusive" a:alt_id="11">
                    <alternative condition="Post-hospitalization care" language="text/javascript">
                      <call id="a29" endpoint="" a:alt_id="12">
                        <parameters>
                          <label>Post-Hospitalization Care</label>
