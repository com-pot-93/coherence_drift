                          <type>:task</type>
                          <arguments/>
                        </parameters>
                      </call>
                    </alternative>
                    <alternative condition="Special treatment" language="text/javascript">
                      <call id="a31" endpoint="" a:alt_id="13">
                        <parameters>
                          <label>Special Treatment</label>
                          <method/>
                          <type>:task</type>
                          <arguments/>
                        </parameters>
