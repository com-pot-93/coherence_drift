<?xml version="1.0"?>
<description xmlns="http://cpee.org/ns/description/1.0" xmlns:a="http://cpee.org/ns/annotation/1.0">
  <call id="a1" endpoint="" a:alt_id="1">
    <parameters>
      <label>Receive File</label>
      <method/>
      <type>:task</type>
      <arguments/>
    </parameters>
  </call>
  <loop mode="pre_test" condition="Positive">
    <call id="a5" endpoint="" a:alt_id="3">
      <parameters>
        <label>Heat Bed and Extruder</label>
        <method/>
        <type>:task</type>
        <arguments/>
      </parameters>
    </call>
    <call id="a9" endpoint="" a:alt_id="4">
      <parameters>
        <label>Send Status Update</label>
        <method/>
        <type>:task</type>
        <arguments/>
      </parameters>
    </call>
    <choose mode="exclusive" a:alt_id="5">
      <alternative condition="Ready to proceed" language="text/javascript">
        <call id="a13" endpoint="" a:alt_id="6">
          <parameters>
            <label>Print Object</label>
            <method/>
            <type>:task</type>
            <arguments/>
          </parameters>
        </call>
        <choose mode="exclusive" a:alt_id="7">
          <alternative condition="Escalation" language="text/javascript"/>
          <alternative condition="Not complete" language="text/javascript">
            <escape a:alt_id="-1"/>
          </alternative>
          <alternative condition="Complete" language="text/javascript">
            <escape a:alt_id="-1"/>
          </alternative>
        </choose>
      </alternative>
      <alternative condition="Heat again" language="text/javascript">
        <call id="a5" endpoint="" a:alt_id="3">
          <parameters>
            <label>Heat Bed and Extruder</label>
            <method/>
            <type>:task</type>
            <arguments/>
          </parameters>
        </call>
        <escape a:alt_id="-1"/>
      </alternative>
      <alternative condition="Do not continue" language="text/javascript">
        <escape a:alt_id="-1"/>
      </alternative>
    </choose>
  </loop>
</description>
