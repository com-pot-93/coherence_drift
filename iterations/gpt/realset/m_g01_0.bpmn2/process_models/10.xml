<?xml version="1.0"?>
<description xmlns="http://cpee.org/ns/description/1.0" xmlns:a="http://cpee.org/ns/annotation/1.0">
  <call id="a1" endpoint="" a:alt_id="2">
    <parameters>
      <label>Check if File Received</label>
      <method/>
      <type>:task</type>
      <arguments/>
    </parameters>
  </call>
  <choose mode="exclusive" a:alt_id="1">
    <alternative condition="File not received" language="text/javascript"/>
    <alternative condition="File received" language="text/javascript">
      <call id="a7" endpoint="" a:alt_id="4">
        <parameters>
          <label>Assess Outcome</label>
          <method/>
          <type>:task</type>
          <arguments/>
        </parameters>
      </call>
      <choose mode="exclusive" a:alt_id="3">
        <alternative condition="Outcome not positive" language="text/javascript"/>
        <alternative condition="Outcome positive" language="text/javascript">
          <call id="a13" endpoint="" a:alt_id="6">
            <parameters>
              <label>Perform Further Check</label>
              <method/>
              <type>:task</type>
              <arguments/>
            </parameters>
          </call>
          <choose mode="exclusive" a:alt_id="5">
            <alternative condition="Check fails" language="text/javascript"/>
            <alternative condition="Check successful" language="text/javascript">
              <call id="a19" endpoint="" a:alt_id="8">
                <parameters>
                  <label>Perform Additional Steps</label>
                  <method/>
                  <type>:task</type>
                  <arguments/>
                </parameters>
              </call>
            </alternative>
          </choose>
        </alternative>
      </choose>
    </alternative>
  </choose>
</description>
