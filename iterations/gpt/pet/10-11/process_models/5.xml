<?xml version="1.0"?>
<description xmlns="http://cpee.org/ns/description/1.0" xmlns:a="http://cpee.org/ns/annotation/1.0">
  <call id="a1" endpoint="" a:alt_id="1">
    <parameters>
      <label>GO starts measurement request</label>
      <method/>
      <type>:task</type>
      <arguments/>
    </parameters>
  </call>
  <call id="a3" endpoint="" a:alt_id="2">
    <parameters>
      <label>MSP receives and reviews request</label>
      <method/>
      <type>:task</type>
      <arguments/>
    </parameters>
  </call>
  <choose mode="exclusive" a:alt_id="3">
    <alternative condition="Denied" language="text/javascript">
      <call id="a7" endpoint="" a:alt_id="4">
        <parameters>
          <label>MSP denies request</label>
          <method/>
          <type>:task</type>
          <arguments/>
        </parameters>
      </call>
      <call id="a11" endpoint="" a:alt_id="5">
        <parameters>
          <label>MSP informs GO of denial</label>
          <method/>
          <type>:task</type>
          <arguments/>
        </parameters>
      </call>
    </alternative>
    <alternative condition="Approved" language="text/javascript">
      <call id="a9" endpoint="" a:alt_id="7">
        <parameters>
          <label>MSP approves and performs measurement</label>
          <method/>
          <type>:task</type>
          <arguments/>
        </parameters>
      </call>
      <choose mode="exclusive" a:alt_id="8">
        <alternative condition="Failure" language="text/javascript">
          <call id="a19" endpoint="" a:alt_id="9">
            <parameters>
              <label>MSP notifies GO of measurement failure</label>
              <method/>
              <type>:task</type>
              <arguments/>
            </parameters>
          </call>
        </alternative>
        <alternative condition="">
          <call id="a21" endpoint="" a:alt_id="10">
            <parameters>
              <label>MSP sends measured values to GO</label>
              <method/>
              <type>:task</type>
              <arguments/>
            </parameters>
          </call>
          <call id="a27" endpoint="" a:alt_id="11">
            <parameters>
              <label>GO processes measured values</label>
              <method/>
              <type>:task</type>
              <arguments/>
            </parameters>
          </call>
          <choose mode="exclusive" a:alt_id="12">
            <alternative condition="Values changed" language="text/javascript">
              <call id="a31" endpoint="" a:alt_id="13">
                <parameters>
                  <label>GO sends updated values to MSP</label>
                  <method/>
                  <type>:task</type>
                  <arguments/>
                </parameters>
              </call>
            </alternative>
            <alternative condition="No change" language="text/javascript"/>
          </choose>
          <call id="a33" endpoint="" a:alt_id="14">
            <parameters>
              <label>GO forwards readings to SP</label>
              <method/>
              <type>:task</type>
              <arguments/>
            </parameters>
          </call>
        </alternative>
      </choose>
    </alternative>
  </choose>
</description>
