<?xml version="1.0"?>
<description xmlns="http://cpee.org/ns/description/1.0" xmlns:a="http://cpee.org/ns/annotation/1.0">
  <call id="a1" endpoint="" a:alt_id="1">
    <parameters>
      <label>MPOO deregisters at the GO</label>
      <method/>
      <type>:task</type>
      <arguments/>
    </parameters>
  </call>
  <call id="a3" endpoint="" a:alt_id="2">
    <parameters>
      <label>GO verifies the deregistration</label>
      <method/>
      <type>:task</type>
      <arguments/>
    </parameters>
  </call>
  <choose mode="exclusive" a:alt_id="3">
    <alternative condition="reject" language="text/javascript">
      <call id="a7" endpoint="" a:alt_id="4">
        <parameters>
          <label>GO rejects the deregistration of the MPOO</label>
          <method/>
          <type>:task</type>
          <arguments/>
        </parameters>
      </call>
    </alternative>
    <alternative condition="">
      <call id="a9" endpoint="" a:alt_id="5">
        <parameters>
          <label>GO preliminarily confirms the deregistration of the MPOO</label>
          <method/>
          <type>:task</type>
          <arguments/>
        </parameters>
      </call>
      <call id="a11" endpoint="" a:alt_id="6">
        <parameters>
          <label>GO prepares the readmission of the measuring point</label>
          <method/>
          <type>:task</type>
          <arguments/>
        </parameters>
      </call>
      <choose mode="exclusive" a:alt_id="7">
        <alternative condition="no confirmation" language="text/javascript"/>
        <alternative condition="confirmation" language="text/javascript">
          <call id="a17" endpoint="" a:alt_id="9">
            <parameters>
              <label>MPOO confirmes the continuation to the MPOO</label>
              <method/>
              <type>:task</type>
              <arguments/>
            </parameters>
          </call>
        </alternative>
      </choose>
      <call id="a15" endpoint="" a:alt_id="8">
        <parameters>
          <label>GO performs the equipment acquisition and / or equipment changes</label>
          <method/>
          <type>:task</type>
          <arguments/>
        </parameters>
      </call>
      <call id="a21" endpoint="" a:alt_id="10">
        <parameters>
          <label>GO assigns the GO as MPO</label>
          <method/>
          <type>:task</type>
          <arguments/>
        </parameters>
      </call>
      <call id="a23" endpoint="" a:alt_id="11">
        <parameters>
          <label>GO informs the MPOO about the end of the assignment of the MPOO</label>
          <method/>
          <type>:task</type>
          <arguments/>
        </parameters>
      </call>
      <call id="a25" endpoint="" a:alt_id="12">
        <parameters>
          <label>GO informs the MPOO about the beginning of the assignment of the GO</label>
          <method/>
          <type>:task</type>
          <arguments/>
        </parameters>
      </call>
      <call id="a27" endpoint="" a:alt_id="13">
        <parameters>
          <label>GO informs the MSPO about the assignment of the GO</label>
          <method/>
          <type>:task</type>
          <arguments/>
        </parameters>
      </call>
    </alternative>
  </choose>
  <call id="a29" endpoint="" a:alt_id="14">
    <parameters>
      <label>GO informs the SP about the assignment of the GO</label>
      <method/>
      <type>:task</type>
      <arguments/>
    </parameters>
  </call>
</description>
