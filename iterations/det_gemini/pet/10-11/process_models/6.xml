<?xml version="1.0"?>
<description xmlns="http://cpee.org/ns/description/1.0" xmlns:a="http://cpee.org/ns/annotation/1.0">
  <call id="a1" endpoint="" a:alt_id="1">
    <parameters>
      <label>GO requests the measurements to the MSP</label>
      <method/>
      <type>:task</type>
      <arguments/>
    </parameters>
  </call>
  <call id="a3" endpoint="" a:alt_id="2">
    <parameters>
      <label>MSP checks the received request</label>
      <method/>
      <type>:task</type>
      <arguments/>
    </parameters>
  </call>
  <choose mode="exclusive" a:alt_id="3">
    <alternative condition="Request denied" language="text/javascript">
      <call id="a7" endpoint="" a:alt_id="4">
        <parameters>
          <label>MSP denies the request of the GO</label>
          <method/>
          <type>:task</type>
          <arguments/>
        </parameters>
      </call>
    </alternative>
    <alternative condition="">
      <call id="a9" endpoint="" a:alt_id="5">
        <parameters>
          <label>MSP performs the measurement</label>
          <method/>
          <type>:task</type>
          <arguments/>
        </parameters>
      </call>
      <choose mode="exclusive" a:alt_id="6">
        <alternative condition="Measurement failed" language="text/javascript">
          <call id="a15" endpoint="" a:alt_id="7">
            <parameters>
              <label>MSP informs the GO about the failure</label>
              <method/>
              <type>:task</type>
              <arguments/>
            </parameters>
          </call>
        </alternative>
        <alternative condition="Measurement successful" language="text/javascript">
          <call id="a17" endpoint="" a:alt_id="8">
            <parameters>
              <label>MSP transmits the measured values to the GO</label>
              <method/>
              <type>:task</type>
              <arguments/>
            </parameters>
          </call>
        </alternative>
      </choose>
      <call id="a23" endpoint="" a:alt_id="10">
        <parameters>
          <label>GO processes the measured values</label>
          <method/>
          <type>:task</type>
          <arguments/>
        </parameters>
      </call>
    </alternative>
  </choose>
  <call id="a25" endpoint="" a:alt_id="12">
    <parameters>
      <label>GO sends the changed values to the MSP</label>
      <method/>
      <type>:task</type>
      <arguments/>
    </parameters>
  </call>
  <call id="a31" endpoint="" a:alt_id="14">
    <parameters>
      <label>GO transmits the readings to the SP</label>
      <method/>
      <type>:task</type>
      <arguments/>
    </parameters>
  </call>
</description>
