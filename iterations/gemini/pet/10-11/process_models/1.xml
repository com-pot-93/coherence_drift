<?xml version="1.0"?>
<description xmlns="http://cpee.org/ns/description/1.0" xmlns:a="http://cpee.org/ns/annotation/1.0">
  <call id="a1" endpoint="" a:alt_id="1">
    <parameters>
      <label>GO requests measurements from MSP</label>
      <method/>
      <type>:task</type>
      <arguments/>
    </parameters>
  </call>
  <call id="a3" endpoint="" a:alt_id="2">
    <parameters>
      <label>MSP checks the received request</label>
      <method/>
      <type>:task</type>
      <arguments/>
    </parameters>
  </call>
  <choose mode="exclusive" a:alt_id="3">
    <alternative condition="Request denied" language="text/javascript">
      <call id="a7" endpoint="" a:alt_id="4">
        <parameters>
          <label>MSP denies the request</label>
          <method/>
          <type>:task</type>
          <arguments/>
        </parameters>
      </call>
    </alternative>
    <alternative condition="Request accepted" language="text/javascript">
      <call id="a9" endpoint="" a:alt_id="5">
        <parameters>
          <label>MSP performs the measurement</label>
          <method/>
          <type>:task</type>
          <arguments/>
        </parameters>
      </call>
      <choose mode="exclusive" a:alt_id="6">
        <alternative condition="Failure" language="text/javascript">
          <call id="a15" endpoint="" a:alt_id="7">
            <parameters>
              <label>MSP informs GO about failure</label>
              <method/>
              <type>:task</type>
              <arguments/>
            </parameters>
          </call>
        </alternative>
        <alternative condition="Success" language="text/javascript">
          <call id="a17" endpoint="" a:alt_id="8">
            <parameters>
              <label>MSP transmits measured values to GO</label>
              <method/>
              <type>:task</type>
              <arguments/>
            </parameters>
          </call>
          <call id="a21" endpoint="" a:alt_id="9">
            <parameters>
              <label>GO processes values</label>
              <method/>
              <type>:task</type>
              <arguments/>
            </parameters>
          </call>
          <call id="a23" endpoint="" a:alt_id="10">
            <parameters>
              <label>GO sends changed values to MSP</label>
              <method/>
              <type>:task</type>
              <arguments/>
            </parameters>
          </call>
          <call id="a25" endpoint="" a:alt_id="11">
            <parameters>
              <label>GO transmits readings to SP</label>
              <method/>
              <type>:task</type>
              <arguments/>
            </parameters>
          </call>
        </alternative>
      </choose>
    </alternative>
  </choose>
</description>
