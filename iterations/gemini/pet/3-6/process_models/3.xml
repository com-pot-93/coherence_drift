<?xml version="1.0"?>
<description xmlns="http://cpee.org/ns/description/1.0" xmlns:a="http://cpee.org/ns/annotation/1.0">
  <choose mode="exclusive" a:alt_id="1">
    <alternative condition="Insurance is inactive" language="text/javascript">
      <call id="a3" endpoint="" a:alt_id="2">
        <parameters>
          <label>Inform claimant of claim rejection</label>
          <method/>
          <type>:task</type>
          <arguments/>
        </parameters>
      </call>
    </alternative>
    <alternative condition="Insurance is active" language="text/javascript">
      <call id="a5" endpoint="" a:alt_id="3">
        <parameters>
          <label>Evaluate claim severity and send forms</label>
          <method/>
          <type>:task</type>
          <arguments/>
        </parameters>
      </call>
      <choose mode="exclusive" a:alt_id="4">
        <alternative condition="Condition is false" language="text/javascript">
          <call id="a11" endpoint="" a:alt_id="7">
            <parameters>
              <label>Proceed to next step</label>
              <method/>
              <type>:task</type>
              <arguments/>
            </parameters>
          </call>
        </alternative>
        <alternative condition="Condition is true" language="text/javascript">
          <call id="a13" endpoint="" a:alt_id="5">
            <parameters>
              <label>Check completeness of forms</label>
              <method/>
              <type>:task</type>
              <arguments/>
            </parameters>
          </call>
        </alternative>
      </choose>
    </alternative>
  </choose>
  <choose mode="exclusive" a:alt_id="6">
    <alternative condition="Forms are complete" language="text/javascript">
      <call id="a19" endpoint="" a:alt_id="9">
        <parameters>
          <label>Register claim</label>
          <method/>
          <type>:task</type>
          <arguments/>
        </parameters>
      </call>
    </alternative>
    <alternative condition="Forms are incomplete" language="text/javascript">
      <call id="a21" endpoint="" a:alt_id="10">
        <parameters>
          <label>Inform claimant to update forms</label>
          <method/>
          <type>:task</type>
          <arguments/>
        </parameters>
      </call>
    </alternative>
  </choose>
</description>
