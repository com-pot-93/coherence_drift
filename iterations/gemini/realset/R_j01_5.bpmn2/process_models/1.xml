<?xml version="1.0"?>
<description xmlns="http://cpee.org/ns/description/1.0" xmlns:a="http://cpee.org/ns/annotation/1.0">
  <call id="a1" endpoint="" a:alt_id="1">
    <parameters>
      <label>Run Machine</label>
      <method/>
      <type>:task</type>
      <arguments/>
    </parameters>
  </call>
  <call id="a3" endpoint="" a:alt_id="2">
    <parameters>
      <label>Check Connection</label>
      <method/>
      <type>:task</type>
      <arguments/>
    </parameters>
  </call>
  <choose mode="exclusive" a:alt_id="3">
    <alternative condition="Yes" language="text/javascript"/>
    <alternative condition="No" language="text/javascript">
      <loop mode="pre_test" condition="Condition A">
        <choose mode="exclusive" a:alt_id="4">
          <alternative condition="Condition A" language="text/javascript">
            <call id="a11" endpoint="" a:alt_id="5">
              <parameters>
                <label>Collect Measurements</label>
                <method/>
                <type>:task</type>
                <arguments/>
              </parameters>
            </call>
            <call id="a15" endpoint="" a:alt_id="6">
              <parameters>
                <label>Calculate OEE</label>
                <method/>
                <type>:task</type>
                <arguments/>
              </parameters>
            </call>
            <choose mode="exclusive" a:alt_id="7">
              <alternative condition="No" language="text/javascript">
                <parallel wait="-1" cancel="last" a:alt_id="8">
                  <parallel_branch>
                    <call id="a23" endpoint="" a:alt_id="9">
                      <parameters>
                        <label>Stop Machine</label>
                        <method/>
                        <type>:task</type>
                        <arguments/>
                      </parameters>
                    </call>
                  </parallel_branch>
                  <parallel_branch>
                    <call id="a25" endpoint="" a:alt_id="11">
                      <parameters>
                        <label>Send Email to Engineer</label>
                        <method/>
                        <type>:task</type>
                        <arguments/>
                      </parameters>
                    </call>
                  </parallel_branch>
                </parallel>
              </alternative>
              <alternative condition="Yes" language="text/javascript">
                <call id="a11" endpoint="" a:alt_id="5">
                  <parameters>
                    <label>Collect Measurements</label>
                    <method/>
                    <type>:task</type>
                    <arguments/>
                  </parameters>
                </call>
                <escape a:alt_id="-1"/>
              </alternative>
            </choose>
          </alternative>
          <alternative condition="Condition B" language="text/javascript"/>
        </choose>
      </loop>
    </alternative>
  </choose>
</description>
